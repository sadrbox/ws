{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Учёт",
	"version": "0.1.0",
	"identifier": "kz.aleppo.erp",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Система автоматизированного учёта",
				"width": 1440,
				"height": 900,
				"minWidth": 1024,
				"minHeight": 640,
				"resizable": true,
				"center": true
			}
		],
		"security": {
			"csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.aleppo.kz http://192.168.1.112:3000 ws://localhost:5173"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.ico"
		],
		"windows": {
			"nsis": {
				"languages": ["Russian"],
				"installMode": "currentUser"
			}
		},
		"resources": [],
		"copyright": "SADR",
		"shortDescription": "Учёт",
		"longDescription": "ERP: торговля, склад, бухгалтерия, ЭСФ/СНТ РК. Работает офлайн."
	}
}
