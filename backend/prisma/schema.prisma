model Tax {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  name              String
  code              String?   @unique
  rate              Decimal?  @db.Decimal(5, 2)
  /// Способ расчёта налога:
  ///   "INCLUDED" — налог включён в цену (НДС в Сумма без налогов);
  ///   "ADDED"    — налог начисляется сверху (Сумма без налогов + Налог).
  calculationMethod String    @default("INCLUDED")
  updatedAt         DateTime  @default(now()) @updatedAt
  deletedAt         DateTime?

