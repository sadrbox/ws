  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(7, 4)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  purchaseUuid      String
  taxes             Json?
  date              DateTime?
