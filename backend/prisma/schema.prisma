generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                          Int                  @id @default(autoincrement())
  uuid                        String               @unique @default(uuid())
  username                    String?
  email                       String?
  password                    String?
  employeeUuid                String?
  isSuperAdmin                Boolean              @default(false)
  avatarPath                  String?
  /// UUID активной (текущей) организации пользователя.
  /// Должен совпадать с одной из записей в userPermissions.
  organizationUuid            String?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @default(now()) @updatedAt
  deletedAt                   DateTime?
  accessRights                AccessRight[]
  notifications               Notification[]
  curatorTodos                Todo[]               @relation("TodoCurator")
  executorTodos               Todo[]               @relation("TodoExecutor")
  employee                    Employee?            @relation(fields: [employeeUuid], references: [uuid], onDelete: SetNull)
  organization                Organization?        @relation("UserOrganization", fields: [organizationUuid], references: [uuid], onDelete: SetNull)
  /// Список организаций, к которым у пользователя есть доступ
  userPermissions             UserPermission[]
  // Авторство документов — заполняется при создании, не редактируется.
  authoredSales               Sale[]               @relation("SaleAuthor")
  authoredPurchases           Purchase[]           @relation("PurchaseAuthor")
  authoredOutgoingInvoices    OutgoingInvoice[]    @relation("OutgoingInvoiceAuthor")
  authoredIncomingInvoices    IncomingInvoice[]    @relation("IncomingInvoiceAuthor")
  authoredPaymentInvoices     PaymentInvoice[]     @relation("PaymentInvoiceAuthor")
  authoredInventoryTransfers  InventoryTransfer[]  @relation("InventoryTransferAuthor")
  authoredCashReceiptOrders   CashReceiptOrder[]   @relation("CashReceiptOrderAuthor")
  authoredCashExpenseOrders   CashExpenseOrder[]   @relation("CashExpenseOrderAuthor")
  authoredPayrollCalculations PayrollCalculation[] @relation("PayrollCalculationAuthor")
  authoredPayrollPayments     PayrollPayment[]     @relation("PayrollPaymentAuthor")
  authoredScheduledTasks      ScheduledTask[]      @relation("ScheduledTaskAuthor")

  @@index([employeeUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("users")
}

/// Членство пользователя в организации с ролью.
/// role: "admin"  — может управлять правами доступа пользователей своей орг.
/// role: "member" — обычный пользователь.
model UserPermission {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  userUuid         String
  organizationUuid String
  /// "admin" | "member"
  role             String   @default("member")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  user         User         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  organization Organization @relation(fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, organizationUuid])
  @@index([userUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("user_permissions")
}

model Organization {
  id                  Int                             @id @default(autoincrement())
  uuid                String                          @unique @default(uuid())
  bin                 String                          @unique @db.VarChar(12)
  shortName           String?
  displayName         String?
  inviteCode          String?                         @unique
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @default(now()) @updatedAt
  deletedAt           DateTime?
  activityHistories   ActivityHistory[]
  cashExpenseOrders   CashExpenseOrder[]              @relation("OrgCashExpenses")
  cashReceiptOrders   CashReceiptOrder[]              @relation("OrgCashReceipts")
  contracts           Contract[]                      @relation("OrgContracts")
  employees           Employee[]                      @relation("EmployeeOrganization")
  incomingInvoices    IncomingInvoice[]               @relation("OrgIncomingInvoices")
  inventoryTransfers  InventoryTransfer[]
  outgoingInvoices    OutgoingInvoice[]               @relation("OrgOutgoingInvoices")
  paymentInvoices     PaymentInvoice[]
  payrollCalculations PayrollCalculation[]            @relation("OrgPayrollCalc")
  payrollPayments     PayrollPayment[]                @relation("OrgPayrollPay")
  purchases           Purchase[]
  sales               Sale[]
  scheduledTasks      ScheduledTask[]
  todos               Todo[]
  users               User[]                          @relation("UserOrganization")
  userPermissions     UserPermission[]
  accessRights        AccessRight[]
  warehouses          Warehouse[]
  employeeHistories   EmployeeHistory[]
  counterparties      Counterparty[]                  @relation("OrgCounterparties")
  products            Product[]                       @relation("OrgProducts")
  brands              Brand[]                         @relation("OrgBrands")
  positions           Position[]                      @relation("OrgPositions")
  contacts            Contact[]                       @relation("OrgContacts")
  contactPersons      ContactPerson[]                 @relation("OrgContactPersons")
  bankAccounts        BankAccount[]                   @relation("OrgBankAccounts")
  accountingSettings  OrganizationAccountingSetting[] @relation("OrgAccountingSettings")

  @@index([updatedAt])
  @@map("organizations")
}

model Counterparty {
  id                Int                @id @default(autoincrement())
  uuid              String             @unique @default(uuid())
  bin               String             @unique @db.VarChar(12)
  shortName         String?
  displayName       String?
  organizationUuid  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  deletedAt         DateTime?
  organization      Organization?      @relation("OrgCounterparties", fields: [organizationUuid], references: [uuid])
  cashExpenseOrders CashExpenseOrder[] @relation("CpCashExpenses")
  cashReceiptOrders CashReceiptOrder[] @relation("CpCashReceipts")
  contracts         Contract[]         @relation("CpContracts")
  incomingInvoices  IncomingInvoice[]  @relation("CpIncomingInvoices")
  outgoingInvoices  OutgoingInvoice[]  @relation("CpOutgoingInvoices")
  paymentInvoices   PaymentInvoice[]
  purchases         Purchase[]
  sales             Sale[]
  todos             Todo[]

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("counterparties")
}

model Contract {
  id                Int                @id @default(autoincrement())
  uuid              String             @unique @default(uuid())
  shortName         String
  contractNumber    String?
  contractText      String?
  startDate         DateTime?
  endDate           DateTime?
  organizationUuid  String?
  counterpartyUuid  String?
  isPrimary         Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  deletedAt         DateTime?
  organization      Organization?      @relation("OrgContracts", fields: [organizationUuid], references: [uuid])
  counterparty      Counterparty?      @relation("CpContracts", fields: [counterpartyUuid], references: [uuid])
  cashExpenseOrders CashExpenseOrder[]
  cashReceiptOrders CashReceiptOrder[]
  incomingInvoices  IncomingInvoice[]
  outgoingInvoices  OutgoingInvoice[]
  paymentInvoices   PaymentInvoice[]
  purchases         Purchase[]
  sales             Sale[]

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([updatedAt])
  @@map("contracts")
}

model AttachedFile {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  ownerType   String
  ownerUuid   String
  fileName    String
  filePath    String
  fileSize    Int?
  mimeType    String?
  description String?
  uploadedAt  DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?

  @@index([ownerType, ownerUuid])
  @@index([updatedAt])
  @@map("attached_files")
}

model ContactType {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(uuid())
  shortName String    @unique
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  contacts  Contact[]

  @@index([updatedAt])
  @@map("contact_types")
}

model Contact {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  value            String        @default("")
  contactTypeUuid  String?
  ownerType        String?
  ownerUuid        String?
  organizationUuid String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contactType      ContactType?  @relation(fields: [contactTypeUuid], references: [uuid])
  organization     Organization? @relation("OrgContacts", fields: [organizationUuid], references: [uuid])

  @@index([contactTypeUuid])
  @@index([ownerType, ownerUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("contacts")
}

model ContactPerson {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  firstName        String?
  lastName         String?
  middleName       String?
  fullName         String?       @db.VarChar(255)
  ownerType        String?
  ownerUuid        String?
  organizationUuid String?
  comment          String?
  avatarPath       String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation("OrgContactPersons", fields: [organizationUuid], references: [uuid])

  @@index([ownerType, ownerUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("contact_persons")
}

model BankAccount {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  ownerType        String?
  ownerUuid        String?
  iban             String
  bik              String?
  bankName         String?
  shortName        String?
  currencyUuid     String?
  organizationUuid String?
  isPrimary        Boolean       @default(false)
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  currency         Currency?     @relation(fields: [currencyUuid], references: [uuid])
  organization     Organization? @relation("OrgBankAccounts", fields: [organizationUuid], references: [uuid])

  @@index([ownerType, ownerUuid])
  @@index([currencyUuid])
  @@index([organizationUuid])
  @@index([iban])
  @@index([bik])
  @@index([updatedAt])
  @@map("bank_accounts")
}

model ActivityHistory {
  id                    Int          @id @default(autoincrement())
  uuid                  String       @unique @default(uuid())
  actionDate            DateTime     @default(now())
  actionType            String
  organizationUuid      String
  organizationShortName String
  bin                   String
  userName              String
  host                  String
  ip                    String?
  city                  String?
  objectId              String
  objectType            String
  objectName            String
  props                 Json?
  organization          Organization @relation(fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@index([actionDate])
  @@index([organizationUuid])
  @@index([objectType, objectId])
  @@map("activity_history")
}

model Todo {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  shortName        String?
  description      String?
  organizationUuid String?
  counterpartyUuid String?
  curatorUuid      String?
  executorUuid     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  deletedAt        DateTime?
  deadline         DateTime?
  deadlineDays     Int?
  status           String         @default("new")
  notifications    Notification[]
  counterparty     Counterparty?  @relation(fields: [counterpartyUuid], references: [uuid])
  curator          User?          @relation("TodoCurator", fields: [curatorUuid], references: [uuid])
  executor         User?          @relation("TodoExecutor", fields: [executorUuid], references: [uuid])
  organization     Organization?  @relation(fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([curatorUuid])
  @@index([executorUuid])
  @@index([status])
  @@index([updatedAt])
  @@map("todos")
}

model Notification {
  id        Int       @id @default(autoincrement())
  uuid      String    @unique @default(uuid())
  userUuid  String
  todoUuid  String?
  title     String
  message   String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?
  todo      Todo?     @relation(fields: [todoUuid], references: [uuid])
  user      User      @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid])
  @@index([todoUuid])
  @@index([userUuid, isRead])
  @@index([updatedAt])
  @@map("notifications")
}

model Warehouse {
  id                     Int                 @id @default(autoincrement())
  uuid                   String              @unique @default(uuid())
  shortName              String
  address                String?
  description            String?
  organizationUuid       String?
  updatedAt              DateTime            @default(now()) @updatedAt
  deletedAt              DateTime?
  inventoryTransfersFrom InventoryTransfer[] @relation("TransferFrom")
  inventoryTransfersTo   InventoryTransfer[] @relation("TransferTo")
  sales                  Sale[]
  organization           Organization?       @relation(fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("warehouses")
}

model Sale {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  amountWithoutVat Decimal?      @db.Decimal(18, 2)
  vatAmount        Decimal?      @db.Decimal(18, 2)
  discountAmount   Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  warehouseUuid    String?
  authorUuid       String
  posted           Boolean       @default(false)
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  saleItems        SaleItem[]
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation(fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])
  warehouse        Warehouse?    @relation(fields: [warehouseUuid], references: [uuid])
  author           User          @relation("SaleAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([warehouseUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("sales")
}

model Purchase {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation(fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])
  author           User          @relation("PurchaseAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("purchases")
}

model OutgoingInvoice {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation("CpOutgoingInvoices", fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation("OrgOutgoingInvoices", fields: [organizationUuid], references: [uuid])
  author           User          @relation("OutgoingInvoiceAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("outgoing_invoices")
}

model IncomingInvoice {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation("CpIncomingInvoices", fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation("OrgIncomingInvoices", fields: [organizationUuid], references: [uuid])
  author           User          @relation("IncomingInvoiceAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("incoming_invoices")
}

model PaymentInvoice {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation(fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])
  author           User          @relation("PaymentInvoiceAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("payment_invoices")
}

model ScheduledTask {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  shortName        String
  description      String?
  cronExpr         String?
  status           String        @default("active")
  lastRunAt        DateTime?
  nextRunAt        DateTime?
  organizationUuid String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])
  author           User          @relation("ScheduledTaskAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([authorUuid])
  @@index([status])
  @@index([updatedAt])
  @@map("scheduled_tasks")
}

model InventoryTransfer {
  id                Int           @id @default(autoincrement())
  uuid              String        @unique @default(uuid())
  date              DateTime      @default(now())
  description       String?
  fromWarehouseUuid String?
  toWarehouseUuid   String?
  organizationUuid  String?
  authorUuid        String
  updatedAt         DateTime      @default(now()) @updatedAt
  deletedAt         DateTime?
  fromWarehouse     Warehouse?    @relation("TransferFrom", fields: [fromWarehouseUuid], references: [uuid])
  organization      Organization? @relation(fields: [organizationUuid], references: [uuid])
  toWarehouse       Warehouse?    @relation("TransferTo", fields: [toWarehouseUuid], references: [uuid])
  author            User          @relation("InventoryTransferAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([fromWarehouseUuid])
  @@index([toWarehouseUuid])
  @@index([organizationUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("inventory_transfers")
}

model CashReceiptOrder {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation("CpCashReceipts", fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation("OrgCashReceipts", fields: [organizationUuid], references: [uuid])
  author           User          @relation("CashReceiptOrderAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("cash_receipt_orders")
}

model CashExpenseOrder {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation("CpCashExpenses", fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation("OrgCashExpenses", fields: [organizationUuid], references: [uuid])
  author           User          @relation("CashExpenseOrderAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("cash_expense_orders")
}

model Brand {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  shortName        String
  organizationUuid String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation("OrgBrands", fields: [organizationUuid], references: [uuid])
  products         Product[]

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("brands")
}

model Product {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  shortName         String
  sku               String?
  brandUuid         String?
  unitOfMeasureUuid String?
  organizationUuid  String?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  brand             Brand?         @relation(fields: [brandUuid], references: [uuid])
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])
  organization      Organization?  @relation("OrgProducts", fields: [organizationUuid], references: [uuid])
  saleItems         SaleItem[]

  @@index([brandUuid])
  @@index([unitOfMeasureUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("products")
}

model SaleItem {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  price             Decimal        @default(0) @db.Decimal(18, 2)
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  /// Стоимость без НДС (графа 13 ЭСФ РК): amount − vatAmount.
  amountWithoutVat  Decimal        @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid String?
  /// Ставка НДС, % — фиксируется по каждой строке для исторической
  /// точности. Справочник «Ставки НДС» удалён — значение берётся
  /// из Настроек учёта организации (OrganizationAccountingSetting.vatRate).
  vatRate           Decimal        @default(12) @db.Decimal(5, 2)
  vatAmount         Decimal        @default(0) @db.Decimal(18, 2)
  /// Ставка акциза в процентах (НК РК ст. 463). 0 — акциз не применяется.
  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  /// Сумма акциза по строке (afterDiscount × exciseRate / 100).
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  saleUuid          String
  taxes             Json?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  sale              Sale           @relation(fields: [saleUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  @@index([saleUuid])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([updatedAt])
  @@map("sale_items")
}

model Employee {
  id                  Int                  @id @default(autoincrement())
  uuid                String               @unique @default(uuid())
  firstName           String?
  lastName            String?
  middleName          String?
  fullName            String?              @db.VarChar(255)
  iin                 String?              @db.VarChar(12)
  avatarPath          String?
  organizationUuid    String?
  updatedAt           DateTime             @default(now()) @updatedAt
  deletedAt           DateTime?
  employeeHistory     EmployeeHistory[]
  payrollCalculations PayrollCalculation[] @relation("PayrollCalcEmployee")
  payrollPayments     PayrollPayment[]     @relation("PayrollPayEmployee")
  organization        Organization?        @relation("EmployeeOrganization", fields: [organizationUuid], references: [uuid])
  users               User[]

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("employees")
}

model Position {
  id                  Int                  @id @default(autoincrement())
  uuid                String               @unique @default(uuid())
  shortName           String
  description         String?
  organizationUuid    String?
  updatedAt           DateTime             @default(now()) @updatedAt
  deletedAt           DateTime?
  organization        Organization?        @relation("OrgPositions", fields: [organizationUuid], references: [uuid])
  employeeHistory     EmployeeHistory[]
  payrollCalculations PayrollCalculation[] @relation("PayrollCalcPosition")

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("positions")
}

model EmployeeHistory {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  eventDate        DateTime      @default(now())
  eventType        String
  salary           Decimal?      @db.Decimal(18, 2)
  employeeUuid     String
  positionUuid     String?
  organizationUuid String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  employee         Employee      @relation(fields: [employeeUuid], references: [uuid], onDelete: Cascade)
  position         Position?     @relation(fields: [positionUuid], references: [uuid])
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])

  @@index([employeeUuid])
  @@index([positionUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("employee_history")
}

model AccessRight {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  modelName        String
  accessLevel      String        @default("none")
  userUuid         String
  /// Права привязаны к конкретной организации.
  /// NULL — права действуют глобально (для суперадминов, legacy-записи).
  organizationUuid String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  user             User          @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, organizationUuid, modelName])
  @@index([userUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("access_rights")
}

model Currency {
  id           Int           @id @default(autoincrement())
  uuid         String        @unique @default(uuid())
  code         String        @unique
  shortName    String
  symbol       String?
  updatedAt    DateTime      @default(now()) @updatedAt
  deletedAt    DateTime?
  bankAccounts BankAccount[]

  @@index([updatedAt])
  @@map("currencies")
}

model PayrollCalculation {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  period           String?       @db.VarChar(7)
  employeeUuid     String?
  organizationUuid String?
  positionUuid     String?
  baseSalary       Decimal       @default(0) @db.Decimal(18, 2)
  opv              Decimal       @default(0) @db.Decimal(18, 2)
  ipn              Decimal       @default(0) @db.Decimal(18, 2)
  socialContrib    Decimal       @default(0) @db.Decimal(18, 2)
  socialTax        Decimal       @default(0) @db.Decimal(18, 2)
  vosms            Decimal       @default(0) @db.Decimal(18, 2)
  oosms            Decimal       @default(0) @db.Decimal(18, 2)
  netSalary        Decimal       @default(0) @db.Decimal(18, 2)
  totalExpense     Decimal       @default(0) @db.Decimal(18, 2)
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  employee         Employee?     @relation("PayrollCalcEmployee", fields: [employeeUuid], references: [uuid])
  organization     Organization? @relation("OrgPayrollCalc", fields: [organizationUuid], references: [uuid])
  position         Position?     @relation("PayrollCalcPosition", fields: [positionUuid], references: [uuid])
  author           User          @relation("PayrollCalculationAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([employeeUuid])
  @@index([organizationUuid])
  @@index([positionUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([period])
  @@index([updatedAt])
  @@map("payroll_calculations")
}

model PayrollPayment {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  date             DateTime      @default(now())
  description      String?
  period           String?       @db.VarChar(7)
  employeeUuid     String?
  organizationUuid String?
  paymentMethod    String?       @default("bank_transfer")
  amount           Decimal       @default(0) @db.Decimal(18, 2)
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  employee         Employee?     @relation("PayrollPayEmployee", fields: [employeeUuid], references: [uuid])
  organization     Organization? @relation("OrgPayrollPay", fields: [organizationUuid], references: [uuid])
  author           User          @relation("PayrollPaymentAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([employeeUuid])
  @@index([organizationUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([period])
  @@index([updatedAt])
  @@map("payroll_payments")
}

model UnitOfMeasure {
  id        Int        @id @default(autoincrement())
  uuid      String     @unique @default(uuid())
  shortName String
  code      String?
  updatedAt DateTime   @default(now()) @updatedAt
  deletedAt DateTime?
  products  Product[]
  saleItems SaleItem[]

  @@index([updatedAt])
  @@map("units_of_measure")
}

model Tax {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  shortName         String
  code              String?   @unique
  rate              Decimal?  @db.Decimal(5, 2)
  /// Способ расчёта налога:
  ///   "INCLUDED" — налог включён в цену (НДС в Стоимость);
  ///   "ADDED"    — налог начисляется сверху (Стоимость + Налог).
  calculationMethod String    @default("INCLUDED")
  updatedAt         DateTime  @default(now()) @updatedAt
  deletedAt         DateTime?

  @@index([updatedAt])
  @@map("taxes")
}

/// Журнал настроек учёта организации.
/// Активная запись на организацию — последняя с deletedAt IS NULL.
/// При обновлении старая помечается deletedAt, создаётся новая.
model OrganizationAccountingSetting {
  id                   Int           @id @default(autoincrement())
  uuid                 String        @unique @default(uuid())
  organizationUuid     String?
  /// Дата начала действия настроек (для исторических запросов).
  startDate            DateTime      @default(now())
  /// Использовать НДС (включает колонки НДС в строках документов).
  useVat               Boolean       @default(false)
  /// Ставка НДС, % — используется для всех строк документов
  /// этой организации. Ранее бралась из справочника VatRate (удалён).
  vatRate              Decimal       @default(12) @db.Decimal(5, 2)
  /// Способ расчёта НДС:
  ///   "INCLUDED" — НДС включён в цену («в сумме»);
  ///   "ADDED"    — НДС начисляется сверху к стоимости («сверху»).
  vatCalculationMethod String        @default("INCLUDED")
  /// Использовать скидки в строках документов продажи.
  useDiscount          Boolean       @default(false)
  /// Использовать акциз (НК РК ст. 463). При true в SaleItemsTable
  /// отображается колонка «Ставка акциза» и «Сумма акциза».
  useExcise            Boolean       @default(false)
  /// Ставка акциза по умолчанию, % (используется как значение по умолчанию
  /// для новых строк документов продажи при useExcise=true).
  exciseRate           Decimal       @default(0) @db.Decimal(8, 4)
  updatedAt            DateTime      @default(now()) @updatedAt
  deletedAt            DateTime?
  organization         Organization? @relation("OrgAccountingSettings", fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([startDate])
  @@index([updatedAt])
  @@map("organization_accounting_settings")
}
