/// Журнал настроек учёта организации.
/// Активная запись на организацию — последняя с deletedAt IS NULL.
/// При обновлении старая помечается deletedAt, создаётся новая.
model OrganizationAccountingSetting {
  id                   Int           @id @default(autoincrement())
  uuid                 String        @unique @default(uuid())
  organizationUuid     String?
  /// Дата начала действия настроек (для исторических запросов).
  startDate            DateTime      @default(now())
  /// Использовать НДС (включает колонки НДС в строках документов).
  useVat               Boolean       @default(false)
  /// Ставка НДС, % — используется для всех строк документов
  /// этой организации. Ранее бралась из справочника VatRate (удалён).
  vatRate              Decimal       @default(12) @db.Decimal(5, 2)
  /// Способ расчёта НДС:
  ///   "INCLUDED" — НДС включён в цену («в сумме»);
  ///   "ADDED"    — НДС начисляется сверху к стоимости («сверху»).
  vatCalculationMethod String        @default("INCLUDED")
  /// Использовать скидки в строках документов продажи.
  useDiscount          Boolean       @default(false)
  /// Использовать акциз (НК РК ст. 463). При true в SaleItemsTable
  /// отображается колонка «Ставка акциза, %» и «Сумма акциза».
  useExcise            Boolean       @default(false)
  /// Ставка акциза по умолчанию, % (используется как значение по умолчанию
  /// для новых строк документов продажи при useExcise=true).
  exciseRate           Decimal       @default(0) @db.Decimal(8, 4)
  updatedAt            DateTime      @default(now()) @updatedAt
  deletedAt            DateTime?
  organization         Organization? @relation("OrgAccountingSettings", fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([startDate])
  @@index([updatedAt])
  @@map("organization_accounting_settings")
}

