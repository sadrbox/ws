  amount                 Decimal?                @db.Decimal(18, 2)
  fromWarehouseUuid      String?
  toWarehouseUuid        String?
  organizationUuid       String?
  authorUuid             String
  posted                 Boolean                 @default(false)
  // Гос-документ: СНТ (сопроводительная накладная на перемещение)
  sntStatus              String?
  sntId                  String?
  sntRegistrationNumber  String?
  sntSentAt              DateTime?
  sntErrorText           String?
  sntXml                 String?                 @db.Text
  updatedAt              DateTime                @default(now()) @updatedAt
