/// Направление движения по банковской выписке.
enum BankStatementDirection {
  bankStatementIn  // поступление
  bankStatementOut // списание
}

/// Банковская выписка (одна операция: in/out). Проводки: in → Дт1030/Кт основание,
/// out → Дт основание/Кт1030 (см. accountingPosting.js). Движение денег по 1030.
model BankStatement {
  id                 Int           @id @default(autoincrement())
  uuid               String        @unique @default(uuid())
  number             String?
  date               DateTime      @default(now())
  comment            String?
  direction          BankStatementDirection @default(bankStatementIn)
  amount             Decimal       @default(0) @db.Decimal(18, 2)
  organizationUuid   String?
  counterpartyUuid   String?
  contractUuid       String?
  bankAccountUuid    String?
  authorUuid         String
  posted             Boolean       @default(true)
  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?
  updatedAt          DateTime      @default(now()) @updatedAt
  deletedAt          DateTime?
  contract           Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty       Counterparty? @relation(fields: [counterpartyUuid], references: [uuid])
  organization       Organization? @relation(fields: [organizationUuid], references: [uuid])
  bankAccount        BankAccount?  @relation(fields: [bankAccountUuid], references: [uuid])
  author             User          @relation("BankStatementAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([bankAccountUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([basisDocumentUuid])
  @@index([updatedAt])
  @@map("bank_statements")
}

/// Счётчики нумерации документов: следующий номер по организации, виду
/// документа и году (сброс с начала года). См. services/documentNumbering.js.
model DocumentSequence {
  id               Int      @id @default(autoincrement())
  organizationUuid String
  docType          String
  year             Int
  lastValue        Int      @default(0)
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([organizationUuid, docType, year])
  @@map("document_sequences")
}

/// Настройки нумерации документов (переопределение префикса/разрядности по виду
/// документа). Глобально для установки. Отсутствие строки → дефолт из
/// services/documentNumbering.js (NUMBER_CONFIG).
model DocumentNumberSetting {
  id               Int      @id @default(autoincrement())
  /// Организация настройки. "__global__" — значения по умолчанию для всех орг.
  organizationUuid String   @default("__global__")
  docType          String
  prefix           String
  padding          Int      @default(6)
  /// Включена ли автонумерация этого вида документа.
  enabled          Boolean  @default(true)
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([organizationUuid, docType])
  @@map("document_number_settings")
}

/// Документ «Установка цен номенклатуры» (периодический). Шапка.
/// Цены, проставленные проведённым документом, денормализуются в Product
/// (последний по дате проведённый документ задаёт текущие цены товара).
model ProductPriceSetting {
  id               Int                       @id @default(autoincrement())
  uuid             String                    @unique @default(uuid())
  number           String?
  date             DateTime                  @default(now())
  comment          String?
  organizationUuid String?
  posted           Boolean                   @default(false)
  authorUuid       String
  updatedAt        DateTime                  @default(now()) @updatedAt
  deletedAt        DateTime?
  items            ProductPriceSettingItem[]
  organization     Organization?             @relation(fields: [organizationUuid], references: [uuid])
  author           User                      @relation("PriceSettingAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("product_price_settings")
}

/// Строка документа «Установка цен»: товар и три цены.
model ProductPriceSettingItem {
  id               Int                 @id @default(autoincrement())
  uuid             String              @unique @default(uuid())
  priceSettingUuid String
  productUuid      String?
  salePrice        Decimal?            @db.Decimal(18, 2)
  purchasePrice    Decimal?            @db.Decimal(18, 2)
  wholesalePrice   Decimal?            @db.Decimal(18, 2)
  updatedAt        DateTime            @default(now()) @updatedAt
  deletedAt        DateTime?
  priceSetting     ProductPriceSetting @relation(fields: [priceSettingUuid], references: [uuid], onDelete: Cascade)
  product          Product?            @relation(fields: [productUuid], references: [uuid])

  @@index([priceSettingUuid])
  @@index([productUuid])
  @@map("product_price_setting_items")
}

/// Справочник «Типы цен» (Цена продажи / закупки / оптовая и т.п.).
/// isDefault — тип, используемый как цена продажи по умолчанию (денормализуется
/// в Product.price для терминала и строк продаж).
model PriceType {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  name             String
  isDefault        Boolean        @default(false)
  sortOrder        Int            @default(100)
  organizationUuid String?
  updatedAt        DateTime       @default(now()) @updatedAt
  deletedAt        DateTime?
  productPrices    ProductPrice[]
  sales            Sale[]
  purchases        Purchase[]

  @@index([organizationUuid])
  @@map("price_types")
}

/// Цена номенклатуры по типу, действующая с указанной даты (вкладка «Цены» в
/// форме товара). Текущая цена типа = последняя по дате (date <= now).
model ProductPrice {
  id            Int        @id @default(autoincrement())
  uuid          String     @unique @default(uuid())
  productUuid   String
  priceTypeUuid String?
  date          DateTime   @default(now())
  price         Decimal?   @db.Decimal(18, 2)
  updatedAt     DateTime   @default(now()) @updatedAt
  deletedAt     DateTime?
  product       Product    @relation(fields: [productUuid], references: [uuid], onDelete: Cascade)
  priceType     PriceType? @relation(fields: [priceTypeUuid], references: [uuid])

  @@index([productUuid])
  @@index([priceTypeUuid])
  @@index([date])
  @@map("product_prices")
}
