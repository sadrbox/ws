  author           User          @relation("MonthCloseAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([periodEnd])
  @@index([date])
  @@index([updatedAt])
  @@map("month_closes")
}

// Фискальный чек (ОФД/Kaspi). Регистр без FK на каждый документ-источник (паттерн
// AccountingEntry): связь через documentType/documentUuid. См. services/fiscal/.
model FiscalReceipt {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  documentType     String
  documentUuid     String
  documentId       Int?
  organizationUuid String?
  provider         String        @default("stub")
  paymentMethod    String        @default("cash")
  amount           Decimal       @default(0) @db.Decimal(18, 2)
  // created | payment_pending | paid | fiscalized | failed | refunded
  status           String        @default("created")
  paymentId        String?
  qrPayload        String?
  fiscalSign       String?
  fiscalNumber     String?
  fiscalDate       DateTime?
  errorMessage     String?
  raw              Json?
  authorUuid       String?
  createdAt        DateTime      @default(now())
