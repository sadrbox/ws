// Перемещение ТМЗ — внутренние перемещения не облагаются НДС/акцизом
// (НК РК ст. 372 п. 2 пп. 3 — не является облагаемым оборотом).
// Поэтому в строках только количество × цена.
model InventoryTransferItem {
  id                    Int               @id @default(autoincrement())
  uuid                  String            @unique @default(uuid())
  quantity              Decimal           @default(0) @db.Decimal(18, 4)
  price                 Decimal           @default(0) @db.Decimal(18, 2)
  amount                Decimal           @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid     String?
  productUuid           String?
  inventoryTransferUuid String
  updatedAt             DateTime          @default(now()) @updatedAt
  deletedAt             DateTime?
  product               Product?          @relation(fields: [productUuid], references: [uuid])
  inventoryTransfer     InventoryTransfer @relation(fields: [inventoryTransferUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure         UnitOfMeasure?    @relation(fields: [unitOfMeasureUuid], references: [uuid])

  @@index([inventoryTransferUuid])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([updatedAt])
  @@map("inventory_transfer_items")
}

model Employee {
