// ─── Регистр накопления «Товары» ─────────────────────────────────────────────
// Регистр движений товаров (приход/расход). Записи создаются ТОЛЬКО при
// проведении документа (posted=true) и удаляются при снятии проведения,
// удалении документа или изменении его строк (полный пересбор по документу).
// Источники движений:
//   purchase          → приход  (+) на warehouseUuid
//   sale              → расход  (−) с warehouseUuid
//   inventory_transfer→ расход (−) с fromWarehouseUuid + приход (+) на toWarehouseUuid
//   sale_return       → приход  (+) на warehouseUuid
//   purchase_return   → расход  (−) с warehouseUuid
// Остатки вычисляются суммированием: Σприход − Σрасход (по товар+склад+орг).
model ProductRegister {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  /// Дата движения = дата документа.
  date              DateTime
  /// Тип движения: "in" (приход) | "out" (расход).
  movementType      String
  /// Количество (всегда положительное; знак задаётся movementType).
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  /// Сумма движения (всегда положительная).
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  warehouseUuid     String?
  organizationUuid  String?
  unitOfMeasureUuid String?
  /// Тип документа-регистратора: purchase | sale | inventory_transfer | sale_return | purchase_return
  documentType      String
  /// UUID документа-регистратора (для пересбора/удаления движений).
  documentUuid      String
  /// Числовой ID документа (для отображения).
  documentId        Int?
  /// UUID строки документа-источника движения.
  documentItemUuid  String?
  createdAt         DateTime       @default(now())
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  warehouse         Warehouse?     @relation(fields: [warehouseUuid], references: [uuid])
  organization      Organization?  @relation(fields: [organizationUuid], references: [uuid])
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  @@index([productUuid])
  @@index([warehouseUuid])
  @@index([organizationUuid])
  @@index([documentType, documentUuid])
  @@index([date])
  @@map("product_register")
}

// ─── Регистр накопления «Резервы товаров» ────────────────────────────────────
// Жёсткий резерв: зарезервированное количество уменьшает доступный для продажи
// остаток. Строки пересобираются из позиций документа «Резервирование» при его
// изменении (reconcileReservationRegister) и удаляются при удалении документа.
// Доступный остаток = Σприход − Σрасход (product_register) − Σактивные резервы,
// при этом резерв-основание самой реализации исключается (он ею и закрывается).
model ReservationRegister {
  id                  Int           @id @default(autoincrement())
  uuid                String        @unique @default(uuid())
  date                DateTime
  quantity            Decimal       @default(0) @db.Decimal(18, 4)
  productUuid         String?
  warehouseUuid       String?
  organizationUuid    String?
  reservationUuid     String
  reservationItemUuid String?
  createdAt           DateTime      @default(now())
  product             Product?      @relation(fields: [productUuid], references: [uuid])
  warehouse           Warehouse?    @relation(fields: [warehouseUuid], references: [uuid])
  organization        Organization? @relation(fields: [organizationUuid], references: [uuid])

  @@index([productUuid, warehouseUuid])
  @@index([reservationUuid])
  @@index([organizationUuid])
  @@map("reservation_register")
}

// ─────────────────────────────────────────────────────────────────────────────
// ПОДСИСТЕМА БУХГАЛТЕРСКОГО УЧЁТА (РК)
// ─────────────────────────────────────────────────────────────────────────────

/// Справочник «Виды субконто» (типы аналитики проводок).
/// code — латинский код (Nomenclature, Warehouse, Counterparty, ...), хранится
/// в ChartOfAccount.subkontoNType и AccountingEntryAnalytic.subkontoType.
/// referenceEndpoint — API-endpoint справочника, по которому резолвится objectUuid
/// в наименование (products, warehouses, ...). NULL — «свободная» аналитика без
/// привязанного справочника (Подразделение, СтатьяЗатрат, Проект, ОС). Новые
/// виды добавляются как записи — структура таблиц не меняется.
model SubkontoType {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  code              String    @unique
  name              String
  referenceEndpoint String?
  referenceModel    String?
  isActive          Boolean   @default(true)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  deletedAt         DateTime?

  @@index([updatedAt])
  @@map("subkonto_types")
}

/// План счетов. organizationUuid = NULL — типовой счёт РК (доступен всем
/// организациям); заполненный — собственный счёт организации. Иерархия — через
/// parentUuid (self-relation) и/или префикс code. До трёх аналитик (субконто) на
/// счёт: subkonto1Type..subkonto3Type ссылаются на SubkontoType.code.
model ChartOfAccount {
  id               Int              @id @default(autoincrement())
  uuid             String           @unique @default(uuid())
  code             String
  name             String
  /// active | passive | active-passive
  accountType      String           @default("active")
  parentUuid       String?
  isActive         Boolean          @default(true)
  isCurrency       Boolean          @default(false)
  isQuantitative   Boolean          @default(false)
  isOffBalance     Boolean          @default(false)
  description      String?
  subkonto1Type    String?
  subkonto2Type    String?
  subkonto3Type    String?
  organizationUuid String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt
  deletedAt        DateTime?
  parent           ChartOfAccount?  @relation("AccountTree", fields: [parentUuid], references: [uuid])
  children         ChartOfAccount[] @relation("AccountTree")
  organization     Organization?    @relation("OrgChartOfAccounts", fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@unique([organizationUuid, code])
  @@index([code])
  @@index([parentUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("chart_of_accounts")
}

/// Бухгалтерская проводка (двойная запись Дт/Кт на одну сумму). Полиморфно
/// привязана к документу-регистратору (documentType + documentUuid), без FK на
/// документ — как product_register. Коды счетов денормализованы для отчётов.
model AccountingEntry {
  id                Int                       @id @default(autoincrement())
  uuid              String                    @unique @default(uuid())
  organizationUuid  String?
  /// Тип документа-регистратора: purchase | sale | sale_return | purchase_return |
  /// cash_receipt_order | cash_expense_order | payroll_calculation | payroll_payment
  documentType      String
  documentUuid      String
  documentId        Int?
  date              DateTime
  debitAccountUuid  String?
  debitAccountCode  String
  creditAccountUuid String?
  creditAccountCode String
  amount            Decimal                   @default(0) @db.Decimal(18, 2)
  description       String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @default(now()) @updatedAt
  analytics         AccountingEntryAnalytic[]
  organization      Organization?             @relation("OrgAccountingEntries", fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([documentType, documentUuid])
  @@index([date])
  @@index([debitAccountCode])
  @@index([creditAccountCode])
  @@map("accounting_entries")
}

/// Аналитика проводки (субконто). Универсальная схема: side (debit/credit) +
/// subkontoType (код вида субконто) + objectUuid (ссылка на объект аналитики).
/// objectName денормализовано для отчётов.
model AccountingEntryAnalytic {
  id                  Int             @id @default(autoincrement())
  uuid                String          @unique @default(uuid())
  accountingEntryUuid String
  /// debit | credit
  side                String
  subkontoType        String
  objectUuid          String?
  objectName          String?
  createdAt           DateTime        @default(now())
  entry               AccountingEntry @relation(fields: [accountingEntryUuid], references: [uuid], onDelete: Cascade)

  @@index([accountingEntryUuid])
  @@index([subkontoType, objectUuid])
  @@map("accounting_entry_analytics")
}

// ─────────────────────────────────────────────────────────────────────────────
