generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           Int                   @id @default(autoincrement())
  uuid                         String                @unique @default(uuid())
  username                     String?
  email                        String?
  password                     String?
  employeeUuid                 String?
  isSuperAdmin                 Boolean               @default(false)
  avatarPath                   String?
  /// UUID активной (текущей) организации пользователя.
  /// Должен совпадать с одной из записей в userSettings.
  organizationUuid             String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @default(now()) @updatedAt
  deletedAt                    DateTime?
  userAccessRights                 UserAccessRight[]
  curatorTodos                 Todo[]                @relation("TodoCurator")
  executorTodos                Todo[]                @relation("TodoExecutor")
  employee                     Employee?             @relation(fields: [employeeUuid], references: [uuid], onDelete: SetNull)
  organization                 Organization?         @relation("UserOrganization", fields: [organizationUuid], references: [uuid], onDelete: SetNull)
  /// Список организаций, к которым у пользователя есть доступ
  userSettings              UserSetting[]
  userDefaults       UserDefault[]
  // Авторство документов — заполняется при создании, не редактируется.
  authoredSales                Sale[]                @relation("SaleAuthor")
  authoredPriceSettings        ProductPriceSetting[] @relation("PriceSettingAuthor")
  authoredPurchases            Purchase[]            @relation("PurchaseAuthor")
  authoredSaleReturns          SaleReturn[]          @relation("SaleReturnAuthor")
  authoredPurchaseReturns      PurchaseReturn[]      @relation("PurchaseReturnAuthor")
  authoredOutgoingInvoices     OutgoingInvoice[]     @relation("OutgoingInvoiceAuthor")
  authoredIncomingInvoices     IncomingInvoice[]     @relation("IncomingInvoiceAuthor")
  authoredPaymentInvoices      PaymentInvoice[]      @relation("PaymentInvoiceAuthor")
  authoredInventoryTransfers   InventoryTransfer[]   @relation("InventoryTransferAuthor")
  authoredCashOrders           CashOrder[]           @relation("CashOrderAuthor")
  authoredPayrollCalculations  PayrollCalculation[]  @relation("PayrollCalculationAuthor")
  authoredPayrollPayments      PayrollPayment[]      @relation("PayrollPaymentAuthor")
  authoredScheduledTasks       ScheduledTask[]       @relation("ScheduledTaskAuthor")
  authoredPurchaseRequisitions PurchaseRequisition[] @relation("PurchaseRequisitionAuthor")
  authoredCommercialOffers     CommercialOffer[]     @relation("CommercialOfferAuthor")
  authoredSalesOrders          SalesOrder[]          @relation("SalesOrderAuthor")
  authoredReservations         Reservation[]         @relation("ReservationAuthor")
  authoredPurchaseOrders       PurchaseOrder[]       @relation("PurchaseOrderAuthor")
  authoredBankStatements       BankStatement[]       @relation("BankStatementAuthor")

  @@index([employeeUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("users")
}

/// Членство пользователя в организации с ролью.
/// role: "admin"  — может управлять правами доступа пользователей своей орг.
/// role: "member" — обычный пользователь.
model UserSetting {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  userUuid         String
  organizationUuid String
  /// "admin" | "member"
  role             String   @default("member")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  user         User         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  organization Organization @relation(fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, organizationUuid])
  @@index([userUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("user_settings")
}

/// Предопределённые значения реквизитов для пользователя в рамках организации.
/// Используются для автозаполнения новых документов (склад, касса, договор, банковский счёт, контакт).
model UserDefault {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  userUuid         String
  organizationUuid String
  /// "bankAccount" | "contract" | "warehouse" | "cashbox" | "contact"
  valueType        String
  valueUuid        String
  valueName        String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  user         User         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  organization Organization @relation(fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, organizationUuid, valueType])
  @@index([userUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("user_defaults")
}

model Organization {
  id                   Int                             @id @default(autoincrement())
  uuid                 String                          @unique @default(uuid())
  bin                  String                          @unique @db.VarChar(12)
  name                 String?
  legalName            String?
  inviteCode           String?                         @unique
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @default(now()) @updatedAt
  deletedAt            DateTime?
  activityHistories    ActivityHistory[]
  cashOrders           CashOrder[]                     @relation("OrgCashOrders")
  contracts            Contract[]                      @relation("OrgContracts")
  employees            Employee[]                      @relation("EmployeeOrganization")
  incomingInvoices     IncomingInvoice[]               @relation("OrgIncomingInvoices")
  inventoryTransfers   InventoryTransfer[]
  outgoingInvoices     OutgoingInvoice[]               @relation("OrgOutgoingInvoices")
  paymentInvoices      PaymentInvoice[]
  payrollCalculations  PayrollCalculation[]            @relation("OrgPayrollCalc")
  payrollPayments      PayrollPayment[]                @relation("OrgPayrollPay")
  purchases            Purchase[]
  purchaseReturns      PurchaseReturn[]
  sales                Sale[]
  saleReturns          SaleReturn[]
  scheduledTasks       ScheduledTask[]
  todos                Todo[]
  users                User[]                          @relation("UserOrganization")
  userSettings        UserSetting[]
  userDefaults UserDefault[]
  userAccessRights           UserAccessRight[]
  warehouses           Warehouse[]
  employeeHistories    EmployeeHistory[]
  counterparties       Counterparty[]                  @relation("OrgCounterparties")
  products             Product[]                       @relation("OrgProducts")
  productPriceSettings ProductPriceSetting[]
  brands               Brand[]                         @relation("OrgBrands")
  positions            Position[]                      @relation("OrgPositions")
  contacts             Contact[]                       @relation("OrgContacts")
  contactPersons       ContactPerson[]                 @relation("OrgContactPersons")
  bankAccounts         BankAccount[]                   @relation("OrgBankAccounts")
  cashboxes            Cashbox[]                       @relation("OrgCashboxes")
  accountingSettings   OrganizationAccountingSetting[] @relation("OrgAccountingSettings")
  purchaseRequisitions PurchaseRequisition[]
  productRegister      ProductRegister[]
  reservationRegister  ReservationRegister[]
  commercialOffers     CommercialOffer[]
  salesOrders          SalesOrder[]
  reservations         Reservation[]
  purchaseOrders       PurchaseOrder[]
  bankStatements       BankStatement[]
  chartOfAccounts      ChartOfAccount[]                @relation("OrgChartOfAccounts")
  accountingEntries    AccountingEntry[]               @relation("OrgAccountingEntries")

  @@index([updatedAt])
  @@map("organizations")
}

model Counterparty {
  id                   Int                   @id @default(autoincrement())
  uuid                 String                @unique @default(uuid())
  bin                  String                @unique @db.VarChar(12)
  name                 String?
  legalName            String?
  organizationUuid     String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  deletedAt            DateTime?
  organization         Organization?         @relation("OrgCounterparties", fields: [organizationUuid], references: [uuid])
  cashOrders           CashOrder[]           @relation("CpCashOrders")
  contracts            Contract[]            @relation("CpContracts")
  incomingInvoices     IncomingInvoice[]     @relation("CpIncomingInvoices")
  outgoingInvoices     OutgoingInvoice[]     @relation("CpOutgoingInvoices")
  paymentInvoices      PaymentInvoice[]
  purchases            Purchase[]
  purchaseReturns      PurchaseReturn[]
  purchaseRequisitions PurchaseRequisition[]
  sales                Sale[]
  saleReturns          SaleReturn[]
  todos                Todo[]
  commercialOffers     CommercialOffer[]
  salesOrders          SalesOrder[]
  reservations         Reservation[]
  purchaseOrders       PurchaseOrder[]
  bankStatements       BankStatement[]

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("counterparties")
}

model Contract {
  id                   Int                   @id @default(autoincrement())
  uuid                 String                @unique @default(uuid())
  name                 String
  contractNumber       String?
  contractText         String?
  startDate            DateTime?
  endDate              DateTime?
  organizationUuid     String?
  counterpartyUuid     String?
  isPrimary            Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  deletedAt            DateTime?
  organization         Organization?         @relation("OrgContracts", fields: [organizationUuid], references: [uuid])
  counterparty         Counterparty?         @relation("CpContracts", fields: [counterpartyUuid], references: [uuid])
  cashOrders           CashOrder[]           @relation("ContractCashOrders")
  incomingInvoices     IncomingInvoice[]
  outgoingInvoices     OutgoingInvoice[]
  paymentInvoices      PaymentInvoice[]
  purchases            Purchase[]
  purchaseReturns      PurchaseReturn[]
  purchaseRequisitions PurchaseRequisition[]
  sales                Sale[]
  saleReturns          SaleReturn[]
  commercialOffers     CommercialOffer[]
  salesOrders          SalesOrder[]
  reservations         Reservation[]
  purchaseOrders       PurchaseOrder[]
  bankStatements       BankStatement[]

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([updatedAt])
  @@map("contracts")
}

model AttachedFile {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  ownerType  String
  ownerUuid  String
  fileName   String
  filePath   String
  fileSize   Int?
  mimeType   String?
  comment    String?
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?

  @@index([ownerType, ownerUuid])
  @@index([updatedAt])
  @@map("attached_files")
}

enum ContactType {
  legal_address
  actual_address
  telephone
  whatsapp
  telegram
  instagram
  facebook
  email
  website
  fax
  other
}

model Contact {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  value            String        @default("")
  contactType      ContactType
  ownerType        String?
  ownerUuid        String?
  organizationUuid String?
  isPrimary        Boolean       @default(false)
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation("OrgContacts", fields: [organizationUuid], references: [uuid])

  @@index([ownerType, ownerUuid])
  @@index([contactType, ownerType, ownerUuid, isPrimary])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("contacts")
}

model ContactPerson {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  firstName        String?
  lastName         String?
  middleName       String?
  fullName         String?       @db.VarChar(255)
  ownerType        String?
  ownerUuid        String?
  organizationUuid String?
  comment          String?
  avatarPath       String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation("OrgContactPersons", fields: [organizationUuid], references: [uuid])

  @@index([ownerType, ownerUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("contact_persons")
}

model BankAccount {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  ownerType        String?
  ownerUuid        String?
  iban             String
  bik              String?
  bankName         String?
  name             String?
  currencyUuid     String?
  isPrimary        Boolean       @default(false)
  organizationUuid String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  currency         Currency?     @relation(fields: [currencyUuid], references: [uuid])
  organization     Organization? @relation("OrgBankAccounts", fields: [organizationUuid], references: [uuid])
  bankStatements   BankStatement[]

  @@index([ownerType, ownerUuid])
  @@index([currencyUuid])
  @@index([organizationUuid])
  @@index([iban])
  @@index([bik])
  @@index([updatedAt])
  @@map("bank_accounts")
}

model ActivityHistory {
  id                    Int          @id @default(autoincrement())
  uuid                  String       @unique @default(uuid())
  actionDate            DateTime     @default(now())
  actionType            String
  organizationUuid      String
  organizationShortName String
  bin                   String
  userName              String
  host                  String
  ip                    String?
  city                  String?
  objectId              String
  objectType            String
  objectName            String
  props                 Json?
  organization          Organization @relation(fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@index([actionDate])
  @@index([organizationUuid])
  @@index([objectType, objectId])
  @@map("activity_history")
}

model Todo {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  name             String?
  description      String?
  organizationUuid String?
  counterpartyUuid String?
  curatorUuid      String?
  executorUuid     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  deadline         DateTime?
  deadlineDays     Int?
  status           String        @default("new")
  counterparty     Counterparty? @relation(fields: [counterpartyUuid], references: [uuid])
  curator          User?         @relation("TodoCurator", fields: [curatorUuid], references: [uuid])
  executor         User?         @relation("TodoExecutor", fields: [executorUuid], references: [uuid])
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([curatorUuid])
  @@index([executorUuid])
  @@index([status])
  @@index([updatedAt])
  @@map("todos")
}

model Warehouse {
  id                     Int                 @id @default(autoincrement())
  uuid                   String              @unique @default(uuid())
  name                   String
  address                String?
  comment                String?
  organizationUuid       String?
  updatedAt              DateTime            @default(now()) @updatedAt
  deletedAt              DateTime?
  inventoryTransfersFrom InventoryTransfer[] @relation("TransferFrom")
  inventoryTransfersTo   InventoryTransfer[] @relation("TransferTo")
  sales                  Sale[]
  saleReturns            SaleReturn[]        @relation("WhSaleReturns")
  purchases              Purchase[]          @relation("WhPurchases")
  purchaseReturns        PurchaseReturn[]    @relation("WhPurchaseReturns")
  organization           Organization?       @relation(fields: [organizationUuid], references: [uuid])
  productRegister        ProductRegister[]
  reservationRegister    ReservationRegister[]
  salesOrders            SalesOrder[]        @relation("WhSalesOrders")
  reservations           Reservation[]       @relation("WhReservations")
  purchaseOrders         PurchaseOrder[]     @relation("WhPurchaseOrders")

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("warehouses")
}

model Cashbox {
  id                Int                @id @default(autoincrement())
  uuid              String             @unique @default(uuid())
  name              String
  organizationUuid  String?
  updatedAt         DateTime           @default(now()) @updatedAt
  deletedAt         DateTime?
  organization      Organization?      @relation("OrgCashboxes", fields: [organizationUuid], references: [uuid])
  cashOrders        CashOrder[]        @relation("CashboxCashOrders")

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("cashboxes")
}

model Sale {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  number             String?
  date             DateTime      @default(now())
  comment          String?
  amount           Decimal?      @db.Decimal(18, 2)
  amountWithoutVat Decimal?      @db.Decimal(18, 2)
  vatAmount        Decimal?      @db.Decimal(18, 2)
  discountAmount   Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  warehouseUuid    String?
  /// Менеджер реализации (Employee.uuid) — аналитика учёта движения продаж
  /// товаров и услуг (НК РК). Необязательное субконто «Manager».
  managerUuid      String?
  /// Тип цен документа (PriceType.uuid) — подставляется из предопределённых
  /// значений пользователя при создании.
  priceTypeUuid    String?
  authorUuid       String
  posted           Boolean       @default(false)
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  saleItems        SaleItem[]
  contract         Contract?     @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation(fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])
  warehouse        Warehouse?    @relation(fields: [warehouseUuid], references: [uuid])
  manager          Employee?     @relation("SaleManager", fields: [managerUuid], references: [uuid])
  priceType        PriceType?    @relation(fields: [priceTypeUuid], references: [uuid], onDelete: SetNull)
  author           User          @relation("SaleAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([warehouseUuid])
  @@index([managerUuid])
  @@index([priceTypeUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@index([basisDocumentUuid])
  @@map("sales")
}

model Purchase {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  number             String?
  date             DateTime       @default(now())
  comment          String?
  amount           Decimal?       @db.Decimal(18, 2)
  amountWithoutVat Decimal?       @db.Decimal(18, 2)
  vatAmount        Decimal?       @db.Decimal(18, 2)
  discountAmount   Decimal?       @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  warehouseUuid    String?
  /// Тип цен документа (PriceType.uuid) — подставляется из предопределённых
  /// значений пользователя при создании.
  priceTypeUuid    String?
  authorUuid       String
  posted           Boolean        @default(false)
  updatedAt        DateTime       @default(now()) @updatedAt
  deletedAt        DateTime?
  purchaseItems    PurchaseItem[]
  contract         Contract?      @relation(fields: [contractUuid], references: [uuid])
  counterparty     Counterparty?  @relation(fields: [counterpartyUuid], references: [uuid])
  organization     Organization?  @relation(fields: [organizationUuid], references: [uuid])
  warehouse        Warehouse?     @relation("WhPurchases", fields: [warehouseUuid], references: [uuid])
  priceType        PriceType?     @relation(fields: [priceTypeUuid], references: [uuid], onDelete: SetNull)
  author           User           @relation("PurchaseAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([warehouseUuid])
  @@index([priceTypeUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@index([basisDocumentUuid])
  @@map("purchases")
}

model OutgoingInvoice {
  id                   Int                   @id @default(autoincrement())
  uuid                 String                @unique @default(uuid())
  number             String?
  date                 DateTime              @default(now())
  comment              String?
  amount               Decimal?              @db.Decimal(18, 2)
  amountWithoutVat     Decimal?              @db.Decimal(18, 2)
  vatAmount            Decimal?              @db.Decimal(18, 2)
  discountAmount       Decimal?              @db.Decimal(18, 2)
  organizationUuid     String?
  counterpartyUuid     String?
  contractUuid         String?
  authorUuid           String
  posted               Boolean               @default(false)
  updatedAt            DateTime              @default(now()) @updatedAt
  deletedAt            DateTime?
  outgoingInvoiceItems OutgoingInvoiceItem[]
  contract             Contract?             @relation(fields: [contractUuid], references: [uuid])
  counterparty         Counterparty?         @relation("CpOutgoingInvoices", fields: [counterpartyUuid], references: [uuid])
  organization         Organization?         @relation("OrgOutgoingInvoices", fields: [organizationUuid], references: [uuid])
  author               User                  @relation("OutgoingInvoiceAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@index([basisDocumentUuid])
  @@map("outgoing_invoices")
}

model IncomingInvoice {
  id                   Int                   @id @default(autoincrement())
  uuid                 String                @unique @default(uuid())
  number             String?
  date                 DateTime              @default(now())
  comment              String?
  amount               Decimal?              @db.Decimal(18, 2)
  amountWithoutVat     Decimal?              @db.Decimal(18, 2)
  vatAmount            Decimal?              @db.Decimal(18, 2)
  discountAmount       Decimal?              @db.Decimal(18, 2)
  organizationUuid     String?
  counterpartyUuid     String?
  contractUuid         String?
  authorUuid           String
  posted               Boolean               @default(false)
  updatedAt            DateTime              @default(now()) @updatedAt
  deletedAt            DateTime?
  incomingInvoiceItems IncomingInvoiceItem[]
  contract             Contract?             @relation(fields: [contractUuid], references: [uuid])
  counterparty         Counterparty?         @relation("CpIncomingInvoices", fields: [counterpartyUuid], references: [uuid])
  organization         Organization?         @relation("OrgIncomingInvoices", fields: [organizationUuid], references: [uuid])
  author               User                  @relation("IncomingInvoiceAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("incoming_invoices")
}

model PaymentInvoice {
  id                  Int                  @id @default(autoincrement())
  uuid                String               @unique @default(uuid())
  number             String?
  date                DateTime             @default(now())
  comment             String?
  amount              Decimal?             @db.Decimal(18, 2)
  amountWithoutVat    Decimal?             @db.Decimal(18, 2)
  vatAmount           Decimal?             @db.Decimal(18, 2)
  discountAmount      Decimal?             @db.Decimal(18, 2)
  organizationUuid    String?
  counterpartyUuid    String?
  contractUuid        String?
  authorUuid          String
  posted              Boolean              @default(false)
  updatedAt           DateTime             @default(now()) @updatedAt
  deletedAt           DateTime?
  paymentInvoiceItems PaymentInvoiceItem[]
  contract            Contract?            @relation(fields: [contractUuid], references: [uuid])
  counterparty        Counterparty?        @relation(fields: [counterpartyUuid], references: [uuid])
  organization        Organization?        @relation(fields: [organizationUuid], references: [uuid])
  author              User                 @relation("PaymentInvoiceAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("payment_invoices")
}

model ScheduledTask {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  name             String
  description      String?
  cronExpr         String?
  status           String        @default("active")
  lastRunAt        DateTime?
  nextRunAt        DateTime?
  organizationUuid String?
  authorUuid       String
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation(fields: [organizationUuid], references: [uuid])
  author           User          @relation("ScheduledTaskAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([authorUuid])
  @@index([status])
  @@index([updatedAt])
  @@map("scheduled_tasks")
}

model InventoryTransfer {
  id                     Int                     @id @default(autoincrement())
  uuid                   String                  @unique @default(uuid())
  number             String?
  date                   DateTime                @default(now())
  comment                String?
  /// Итоговая сумма по строкам (Σ quantity × price). Без НДС/акциза —
  /// внутренние перемещения ТМЗ не облагаются косвенными налогами.
  amount                 Decimal?                @db.Decimal(18, 2)
  fromWarehouseUuid      String?
  toWarehouseUuid        String?
  organizationUuid       String?
  authorUuid             String
  posted                 Boolean                 @default(false)
  updatedAt              DateTime                @default(now()) @updatedAt
  deletedAt              DateTime?
  inventoryTransferItems InventoryTransferItem[]
  fromWarehouse          Warehouse?              @relation("TransferFrom", fields: [fromWarehouseUuid], references: [uuid])
  organization           Organization?           @relation(fields: [organizationUuid], references: [uuid])
  toWarehouse            Warehouse?              @relation("TransferTo", fields: [toWarehouseUuid], references: [uuid])
  author                 User                    @relation("InventoryTransferAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([fromWarehouseUuid])
  @@index([toWarehouseUuid])
  @@index([organizationUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("inventory_transfers")
}



/// Кассовый ордер (объединяет ПКО и РКО). direction задаёт тип:
/// "receipt" — приходный (ПКО), "expense" — расходный (РКО). Документ-тип для
/// проводок/нумерации выводится из direction (cash_receipt_order / cash_expense_order).
model CashOrder {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  /// "receipt" (ПКО) | "expense" (РКО)
  direction        String
  number           String?
  date             DateTime      @default(now())
  comment          String?
  amount           Decimal?      @db.Decimal(18, 2)
  organizationUuid String?
  counterpartyUuid String?
  contractUuid     String?
  cashboxUuid      String?
  authorUuid       String
  posted           Boolean       @default(true)
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  cashbox          Cashbox?      @relation("CashboxCashOrders", fields: [cashboxUuid], references: [uuid])
  contract         Contract?     @relation("ContractCashOrders", fields: [contractUuid], references: [uuid])
  counterparty     Counterparty? @relation("CpCashOrders", fields: [counterpartyUuid], references: [uuid])
  organization     Organization? @relation("OrgCashOrders", fields: [organizationUuid], references: [uuid])
  author           User          @relation("CashOrderAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([cashboxUuid])
  @@index([authorUuid])
  @@index([direction])
  @@index([date])
  @@index([updatedAt])
  @@map("cash_orders")
}

model Brand {
  id               Int           @id @default(autoincrement())
  uuid             String        @unique @default(uuid())
  name             String
  organizationUuid String?
  updatedAt        DateTime      @default(now()) @updatedAt
  deletedAt        DateTime?
  organization     Organization? @relation("OrgBrands", fields: [organizationUuid], references: [uuid])
  products         Product[]

  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("brands")
}

model Product {
  id                       Int                       @id @default(autoincrement())
  uuid                     String                    @unique @default(uuid())
  name                     String
  sku                      String?
  barcode                  String?
  isService                Boolean                   @default(false)
  /// Цены (прайс-лист). Текущие значения денормализуются из последнего
  /// проведённого документа «Установка цен номенклатуры» (по дате). price —
  /// цена продажи (автоподстановка в продажи/терминал).
  price                    Decimal?                  @db.Decimal(18, 2)
  purchasePrice            Decimal?                  @db.Decimal(18, 2)
  wholesalePrice           Decimal?                  @db.Decimal(18, 2)
  brandUuid                String?
  unitOfMeasureUuid        String?
  organizationUuid         String?
  updatedAt                DateTime                  @default(now()) @updatedAt
  deletedAt                DateTime?
  brand                    Brand?                    @relation(fields: [brandUuid], references: [uuid])
  unitOfMeasure            UnitOfMeasure?            @relation(fields: [unitOfMeasureUuid], references: [uuid])
  organization             Organization?             @relation("OrgProducts", fields: [organizationUuid], references: [uuid])
  saleItems                SaleItem[]
  saleReturnItems          SaleReturnItem[]
  purchaseItems            PurchaseItem[]
  purchaseReturnItems      PurchaseReturnItem[]
  outgoingInvoiceItems     OutgoingInvoiceItem[]
  incomingInvoiceItems     IncomingInvoiceItem[]
  paymentInvoiceItems      PaymentInvoiceItem[]
  purchaseRequisitionItems PurchaseRequisitionItem[]
  inventoryTransferItems   InventoryTransferItem[]
  productRegister          ProductRegister[]
  commercialOfferItems     CommercialOfferItem[]
  salesOrderItems          SalesOrderItem[]
  reservationItems         ReservationItem[]
  purchaseOrderItems       PurchaseOrderItem[]
  reservationRegister      ReservationRegister[]
  barcodes                 ProductBarcode[]
  priceSettingItems        ProductPriceSettingItem[]
  productPrices            ProductPrice[]

  @@index([brandUuid])
  @@index([unitOfMeasureUuid])
  @@index([organizationUuid])
  @@index([barcode])
  @@index([updatedAt])
  @@map("products")
}

/// Штрих-коды номенклатуры (один товар — много штрих-кодов).
model ProductBarcode {
  id          Int       @id @default(autoincrement())
  uuid        String    @unique @default(uuid())
  barcode     String
  /// Назначение/пометка штрих-кода (напр. «упаковка», «блок»).
  comment     String?
  productUuid String
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?
  product     Product   @relation(fields: [productUuid], references: [uuid], onDelete: Cascade)

  @@index([productUuid])
  @@index([barcode])
  @@index([updatedAt])
  @@map("product_barcodes")
}

model SaleItem {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  price             Decimal        @default(0) @db.Decimal(18, 2)
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  /// Облагаемый оборот по НДС (графа 13 ЭСФ РК): amount − vatAmount.
  amountWithoutVat  Decimal        @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid String?
  /// Ставка НДС, % — фиксируется по каждой строке для исторической
  /// точности. Справочник «Ставки НДС» удалён — значение берётся
  /// из Настроек учёта организации (OrganizationAccountingSetting.vatRate).
  vatRate           Decimal        @default(12) @db.Decimal(5, 2)
  vatAmount         Decimal        @default(0) @db.Decimal(18, 2)
  /// Ставка акциза в процентах (НК РК ст. 463). 0 — акциз не применяется.
  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  /// Сумма акциза по строке (afterDiscount × exciseRate / 100).
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(7, 4)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  saleUuid          String
  taxes             Json?
  date              DateTime?
  posted            Boolean        @default(false)
  organizationUuid  String?
  counterpartyUuid  String?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  sale              Sale           @relation(fields: [saleUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  sourceRowId       String?

  @@index([saleUuid])
  @@index([sourceRowId])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([date])
  @@index([posted])
  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([updatedAt])
  @@map("sale_items")
}

// ─── Позиции документов торговли (НК РК ст. 412 ─ ЭСФ) ────────────────────────
// Все *Item модели зеркалят SaleItem по структуре: количество/цена/НДС/акциз/
// Сумма скидки + ссылка на родительский документ. Расчёт сумм по строкам
// идентичен (см. backend/api/router/_documentItemsFactory.js).

model PurchaseItem {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  price             Decimal        @default(0) @db.Decimal(18, 2)
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  amountWithoutVat  Decimal        @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid String?
  vatRate           Decimal        @default(12) @db.Decimal(5, 2)
  vatAmount         Decimal        @default(0) @db.Decimal(18, 2)
  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(7, 4)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  purchaseUuid      String
  taxes             Json?
  date              DateTime?
  posted            Boolean        @default(false)
  organizationUuid  String?
  counterpartyUuid  String?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  purchase          Purchase       @relation(fields: [purchaseUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  sourceRowId       String?

  @@index([purchaseUuid])
  @@index([sourceRowId])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([date])
  @@index([posted])
  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([updatedAt])
  @@map("purchase_items")
}

