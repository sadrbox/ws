// ─── Регистр накопления «Товары» ─────────────────────────────────────────────
// Регистр движений товаров (приход/расход). Записи создаются ТОЛЬКО при
// проведении документа (posted=true) и удаляются при снятии проведения,
// удалении документа или изменении его строк (полный пересбор по документу).
// Источники движений:
//   purchase          → приход  (+) на warehouseUuid
//   sale              → расход  (−) с warehouseUuid
//   inventory_transfer→ расход (−) с fromWarehouseUuid + приход (+) на toWarehouseUuid
//   sale_return       → приход  (+) на warehouseUuid
//   purchase_return   → расход  (−) с warehouseUuid
// Остатки вычисляются суммированием: Σприход − Σрасход (по товар+склад+орг).
model ProductRegister {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  /// Дата движения = дата документа.
  date              DateTime
  /// Тип движения: "in" (приход) | "out" (расход).
  movementType      String
  /// Количество (всегда положительное; знак задаётся movementType).
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  /// Сумма движения (всегда положительная).
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  warehouseUuid     String?
  organizationUuid  String?
  unitOfMeasureUuid String?
  /// Тип документа-регистратора: purchase | sale | inventory_transfer | sale_return | purchase_return
  documentType      String
  /// UUID документа-регистратора (для пересбора/удаления движений).
  documentUuid      String
  /// Числовой ID документа (для отображения).
  documentId        Int?
  /// UUID строки документа-источника движения.
  documentItemUuid  String?
  createdAt         DateTime       @default(now())
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  warehouse         Warehouse?     @relation(fields: [warehouseUuid], references: [uuid])
  organization      Organization?  @relation(fields: [organizationUuid], references: [uuid])
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  @@index([productUuid])
  @@index([warehouseUuid])
  @@index([organizationUuid])
  @@index([documentType, documentUuid])
  @@index([date])
  @@map("product_register")
}

// ─── Регистр накопления «Резервы товаров» ────────────────────────────────────
// Жёсткий резерв: зарезервированное количество уменьшает доступный для продажи
// остаток. Строки пересобираются из позиций документа «Резервирование» при его
// изменении (reconcileReservationRegister) и удаляются при удалении документа.
// Доступный остаток = Σприход − Σрасход (product_register) − Σактивные резервы,
// при этом резерв-основание самой реализации исключается (он ею и закрывается).
model ReservationRegister {
  id                  Int           @id @default(autoincrement())
  uuid                String        @unique @default(uuid())
  date                DateTime
  quantity            Decimal       @default(0) @db.Decimal(18, 4)
  productUuid         String?
  warehouseUuid       String?
  organizationUuid    String?
  reservationUuid     String
  reservationItemUuid String?
  createdAt           DateTime      @default(now())
  product             Product?      @relation(fields: [productUuid], references: [uuid])
  warehouse           Warehouse?    @relation(fields: [warehouseUuid], references: [uuid])
  organization        Organization? @relation(fields: [organizationUuid], references: [uuid])

  @@index([productUuid, warehouseUuid])
  @@index([reservationUuid])
  @@index([organizationUuid])
  @@map("reservation_register")
}

// ─────────────────────────────────────────────────────────────────────────────
// ПОДСИСТЕМА БУХГАЛТЕРСКОГО УЧЁТА (РК)
// ─────────────────────────────────────────────────────────────────────────────

/// Справочник «Виды субконто» (типы аналитики проводок).
/// code — латинский код (Nomenclature, Warehouse, Counterparty, ...), хранится
/// в ChartOfAccount.subkontoNType и AccountingEntryAnalytic.subkontoType.
/// referenceEndpoint — API-endpoint справочника, по которому резолвится objectUuid
/// в наименование (products, warehouses, ...). NULL — «свободная» аналитика без
/// привязанного справочника (Подразделение, СтатьяЗатрат, Проект, ОС). Новые
/// виды добавляются как записи — структура таблиц не меняется.
model SubkontoType {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid())
  code              String    @unique
  name              String
  referenceEndpoint String?
  referenceModel    String?
  isActive          Boolean   @default(true)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  deletedAt         DateTime?

  @@index([updatedAt])
  @@map("subkonto_types")
}

/// План счетов. organizationUuid = NULL — типовой счёт РК (доступен всем
/// организациям); заполненный — собственный счёт организации. Иерархия — через
/// parentUuid (self-relation) и/или префикс code. До трёх аналитик (субконто) на
/// счёт: subkonto1Type..subkonto3Type ссылаются на SubkontoType.code.
model ChartOfAccount {
  id               Int              @id @default(autoincrement())
  uuid             String           @unique @default(uuid())
  code             String
  name             String
  /// active | passive | active-passive
  accountType      String           @default("active")
  parentUuid       String?
  isActive         Boolean          @default(true)
  isCurrency       Boolean          @default(false)
  isQuantitative   Boolean          @default(false)
  isOffBalance     Boolean          @default(false)
  description      String?
  subkonto1Type    String?
  subkonto2Type    String?
  subkonto3Type    String?
  organizationUuid String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @default(now()) @updatedAt
  deletedAt        DateTime?
  parent           ChartOfAccount?  @relation("AccountTree", fields: [parentUuid], references: [uuid])
  children         ChartOfAccount[] @relation("AccountTree")
  organization     Organization?    @relation("OrgChartOfAccounts", fields: [organizationUuid], references: [uuid], onDelete: Cascade)

  @@unique([organizationUuid, code])
  @@index([code])
  @@index([parentUuid])
  @@index([organizationUuid])
  @@index([updatedAt])
  @@map("chart_of_accounts")
}

/// Бухгалтерская проводка (двойная запись Дт/Кт на одну сумму). Полиморфно
/// привязана к документу-регистратору (documentType + documentUuid), без FK на
/// документ — как product_register. Коды счетов денормализованы для отчётов.
model AccountingEntry {
  id                Int                       @id @default(autoincrement())
  uuid              String                    @unique @default(uuid())
  organizationUuid  String?
  /// Тип документа-регистратора: purchase | sale | sale_return | purchase_return |
  /// cash_receipt_order | cash_expense_order | payroll_calculation | payroll_payment
  documentType      String
  documentUuid      String
  documentId        Int?
  date              DateTime
  debitAccountUuid  String?
  debitAccountCode  String
  creditAccountUuid String?
  creditAccountCode String
  amount            Decimal                   @default(0) @db.Decimal(18, 2)
  description       String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @default(now()) @updatedAt
  analytics         AccountingEntryAnalytic[]
  organization      Organization?             @relation("OrgAccountingEntries", fields: [organizationUuid], references: [uuid])

  @@index([organizationUuid])
  @@index([documentType, documentUuid])
  @@index([date])
  @@index([debitAccountCode])
  @@index([creditAccountCode])
  @@map("accounting_entries")
}

/// Аналитика проводки (субконто). Универсальная схема: side (debit/credit) +
/// subkontoType (код вида субконто) + objectUuid (ссылка на объект аналитики).
/// objectName денормализовано для отчётов.
model AccountingEntryAnalytic {
  id                  Int             @id @default(autoincrement())
  uuid                String          @unique @default(uuid())
  accountingEntryUuid String
  /// debit | credit
  side                String
  subkontoType        String
  objectUuid          String?
  objectName          String?
  createdAt           DateTime        @default(now())
  entry               AccountingEntry @relation(fields: [accountingEntryUuid], references: [uuid], onDelete: Cascade)

  @@index([accountingEntryUuid])
  @@index([subkontoType, objectUuid])
  @@map("accounting_entry_analytics")
}

// ─────────────────────────────────────────────────────────────────────────────
// ДОПОЛНИТЕЛЬНЫЕ ДОКУМЕНТЫ ЦЕПОЧЕК (заказы, КП, резерв, банковская выписка)
// Зеркалят структуру PurchaseRequisition (header + items) + поля основания.
// ─────────────────────────────────────────────────────────────────────────────

/// Коммерческое предложение (начало цепочки продажи). Не двигает ТМЗ и не
/// формирует проводки — участвует только в цепочках оснований.
model CommercialOffer {
  id                   Int                   @id @default(autoincrement())
  uuid                 String                @unique @default(uuid())
  number               String?
  date                 DateTime              @default(now())
  comment              String?
  amount               Decimal?              @db.Decimal(18, 2)
  amountWithoutVat     Decimal?              @db.Decimal(18, 2)
  vatAmount            Decimal?              @db.Decimal(18, 2)
  discountAmount       Decimal?              @db.Decimal(18, 2)
  organizationUuid     String?
  counterpartyUuid     String?
  contractUuid         String?
  authorUuid           String
  posted               Boolean               @default(false)
  basisDocumentType    String?
  basisDocumentUuid    String?
  basisDocumentLabel   String?
  updatedAt            DateTime              @default(now()) @updatedAt
  deletedAt            DateTime?
  commercialOfferItems CommercialOfferItem[]
  contract             Contract?             @relation(fields: [contractUuid], references: [uuid])
  counterparty         Counterparty?         @relation(fields: [counterpartyUuid], references: [uuid])
  organization         Organization?         @relation(fields: [organizationUuid], references: [uuid])
  author               User                  @relation("CommercialOfferAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([basisDocumentUuid])
  @@index([updatedAt])
  @@map("commercial_offers")
}

model CommercialOfferItem {
  id                  Int             @id @default(autoincrement())
  uuid                String          @unique @default(uuid())
  quantity            Decimal         @default(0) @db.Decimal(18, 4)
  price               Decimal         @default(0) @db.Decimal(18, 2)
  amount              Decimal         @default(0) @db.Decimal(18, 2)
  amountWithoutVat    Decimal         @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid   String?
  vatRate             Decimal         @default(12) @db.Decimal(5, 2)
  vatAmount           Decimal         @default(0) @db.Decimal(18, 2)
  exciseRate          Decimal         @default(0) @db.Decimal(8, 4)
  exciseAmount        Decimal         @default(0) @db.Decimal(18, 2)
  discountPercent     Decimal         @default(0) @db.Decimal(5, 2)
  discountAmount      Decimal         @default(0) @db.Decimal(18, 2)
  productUuid         String?
  commercialOfferUuid String
  taxes               Json?
  date                DateTime?
  posted              Boolean         @default(false)
  organizationUuid    String?
  counterpartyUuid    String?
  updatedAt           DateTime        @default(now()) @updatedAt
  deletedAt           DateTime?
  product             Product?        @relation(fields: [productUuid], references: [uuid])
  commercialOffer     CommercialOffer @relation(fields: [commercialOfferUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure       UnitOfMeasure?  @relation(fields: [unitOfMeasureUuid], references: [uuid])

  sourceRowId String?

  @@index([commercialOfferUuid])
  @@index([sourceRowId])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([updatedAt])
  @@map("commercial_offer_items")
}

/// Заказ покупателя. basis = commercial_offer. Не двигает ТМЗ/проводки.
model SalesOrder {
  id                 Int              @id @default(autoincrement())
  uuid               String           @unique @default(uuid())
  number             String?
  date               DateTime         @default(now())
  comment            String?
  amount             Decimal?         @db.Decimal(18, 2)
  amountWithoutVat   Decimal?         @db.Decimal(18, 2)
  vatAmount          Decimal?         @db.Decimal(18, 2)
  discountAmount     Decimal?         @db.Decimal(18, 2)
  organizationUuid   String?
  counterpartyUuid   String?
  contractUuid       String?
  warehouseUuid      String?
  authorUuid         String
  posted             Boolean          @default(false)
  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?
  updatedAt          DateTime         @default(now()) @updatedAt
  deletedAt          DateTime?
  salesOrderItems    SalesOrderItem[]
  contract           Contract?        @relation(fields: [contractUuid], references: [uuid])
  counterparty       Counterparty?    @relation(fields: [counterpartyUuid], references: [uuid])
  organization       Organization?    @relation(fields: [organizationUuid], references: [uuid])
  warehouse          Warehouse?       @relation("WhSalesOrders", fields: [warehouseUuid], references: [uuid])
  author             User             @relation("SalesOrderAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([warehouseUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([basisDocumentUuid])
  @@index([updatedAt])
  @@map("sales_orders")
}

model SalesOrderItem {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  price             Decimal        @default(0) @db.Decimal(18, 2)
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  amountWithoutVat  Decimal        @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid String?
  vatRate           Decimal        @default(12) @db.Decimal(5, 2)
  vatAmount         Decimal        @default(0) @db.Decimal(18, 2)
  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  salesOrderUuid    String
  taxes             Json?
  date              DateTime?
  posted            Boolean        @default(false)
  organizationUuid  String?
  counterpartyUuid  String?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  salesOrder        SalesOrder     @relation(fields: [salesOrderUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  sourceRowId String?

  @@index([salesOrderUuid])
  @@index([sourceRowId])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([updatedAt])
  @@map("sales_order_items")
}

/// Резервирование товара. basis = sales_order. (Регистр резервов — вне объёма;
/// документ фиксирует зарезервированное количество для цепочки.)
model Reservation {
  id                 Int               @id @default(autoincrement())
  uuid               String            @unique @default(uuid())
  number             String?
  date               DateTime          @default(now())
  comment            String?
  amount             Decimal?          @db.Decimal(18, 2)
  amountWithoutVat   Decimal?          @db.Decimal(18, 2)
  vatAmount          Decimal?          @db.Decimal(18, 2)
  discountAmount     Decimal?          @db.Decimal(18, 2)
  organizationUuid   String?
  counterpartyUuid   String?
  contractUuid       String?
  warehouseUuid      String?
  authorUuid         String
  posted             Boolean           @default(false)
  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?
  updatedAt          DateTime          @default(now()) @updatedAt
  deletedAt          DateTime?
  reservationItems   ReservationItem[]
  contract           Contract?         @relation(fields: [contractUuid], references: [uuid])
  counterparty       Counterparty?     @relation(fields: [counterpartyUuid], references: [uuid])
  organization       Organization?     @relation(fields: [organizationUuid], references: [uuid])
  warehouse          Warehouse?        @relation("WhReservations", fields: [warehouseUuid], references: [uuid])
  author             User              @relation("ReservationAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([warehouseUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([basisDocumentUuid])
  @@index([updatedAt])
  @@map("reservations")
}

model ReservationItem {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  price             Decimal        @default(0) @db.Decimal(18, 2)
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  amountWithoutVat  Decimal        @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid String?
  vatRate           Decimal        @default(12) @db.Decimal(5, 2)
  vatAmount         Decimal        @default(0) @db.Decimal(18, 2)
  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  reservationUuid   String
  taxes             Json?
  date              DateTime?
  posted            Boolean        @default(false)
  organizationUuid  String?
  counterpartyUuid  String?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  reservation       Reservation    @relation(fields: [reservationUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  sourceRowId String?

  @@index([reservationUuid])
  @@index([sourceRowId])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([updatedAt])
  @@map("reservation_items")
}

/// Заказ поставщику. basis = purchase_requisition. Не двигает ТМЗ/проводки.
model PurchaseOrder {
  id                 Int                 @id @default(autoincrement())
  uuid               String              @unique @default(uuid())
  number             String?
  date               DateTime            @default(now())
  comment            String?
  amount             Decimal?            @db.Decimal(18, 2)
  amountWithoutVat   Decimal?            @db.Decimal(18, 2)
  vatAmount          Decimal?            @db.Decimal(18, 2)
  discountAmount     Decimal?            @db.Decimal(18, 2)
  organizationUuid   String?
  counterpartyUuid   String?
  contractUuid       String?
  warehouseUuid      String?
  authorUuid         String
  posted             Boolean             @default(false)
  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?
  updatedAt          DateTime            @default(now()) @updatedAt
  deletedAt          DateTime?
  purchaseOrderItems PurchaseOrderItem[]
  contract           Contract?           @relation(fields: [contractUuid], references: [uuid])
  counterparty       Counterparty?       @relation(fields: [counterpartyUuid], references: [uuid])
  organization       Organization?       @relation(fields: [organizationUuid], references: [uuid])
  warehouse          Warehouse?          @relation("WhPurchaseOrders", fields: [warehouseUuid], references: [uuid])
  author             User                @relation("PurchaseOrderAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([warehouseUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([basisDocumentUuid])
  @@index([updatedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique @default(uuid())
  quantity          Decimal        @default(0) @db.Decimal(18, 4)
  price             Decimal        @default(0) @db.Decimal(18, 2)
  amount            Decimal        @default(0) @db.Decimal(18, 2)
  amountWithoutVat  Decimal        @default(0) @db.Decimal(18, 2)
  unitOfMeasureUuid String?
  vatRate           Decimal        @default(12) @db.Decimal(5, 2)
  vatAmount         Decimal        @default(0) @db.Decimal(18, 2)
  exciseRate        Decimal        @default(0) @db.Decimal(8, 4)
  exciseAmount      Decimal        @default(0) @db.Decimal(18, 2)
  discountPercent   Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(18, 2)
  productUuid       String?
  purchaseOrderUuid String
  taxes             Json?
  date              DateTime?
  posted            Boolean        @default(false)
  organizationUuid  String?
  counterpartyUuid  String?
  updatedAt         DateTime       @default(now()) @updatedAt
  deletedAt         DateTime?
  product           Product?       @relation(fields: [productUuid], references: [uuid])
  purchaseOrder     PurchaseOrder  @relation(fields: [purchaseOrderUuid], references: [uuid], onDelete: Cascade)
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitOfMeasureUuid], references: [uuid])

  sourceRowId String?

  @@index([purchaseOrderUuid])
  @@index([sourceRowId])
  @@index([productUuid])
  @@index([unitOfMeasureUuid])
  @@index([updatedAt])
  @@map("purchase_order_items")
}

/// Направление движения по банковской выписке.
enum BankStatementDirection {
  bankStatementIn // поступление
  bankStatementOut // списание
}

/// Банковская выписка (одна операция: in/out). Проводки: in → Дт1030/Кт основание,
/// out → Дт основание/Кт1030 (см. accountingPosting.js). Движение денег по 1030.
model BankStatement {
  id                 Int                    @id @default(autoincrement())
  uuid               String                 @unique @default(uuid())
  number             String?
  date               DateTime               @default(now())
  comment            String?
  direction          BankStatementDirection @default(bankStatementIn)
  amount             Decimal                @default(0) @db.Decimal(18, 2)
  organizationUuid   String?
  counterpartyUuid   String?
  contractUuid       String?
  bankAccountUuid    String?
  authorUuid         String
  posted             Boolean                @default(true)
  basisDocumentType  String?
  basisDocumentUuid  String?
  basisDocumentLabel String?
  updatedAt          DateTime               @default(now()) @updatedAt
  deletedAt          DateTime?
  contract           Contract?              @relation(fields: [contractUuid], references: [uuid])
  counterparty       Counterparty?          @relation(fields: [counterpartyUuid], references: [uuid])
  organization       Organization?          @relation(fields: [organizationUuid], references: [uuid])
  bankAccount        BankAccount?           @relation(fields: [bankAccountUuid], references: [uuid])
  author             User                   @relation("BankStatementAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([counterpartyUuid])
  @@index([contractUuid])
  @@index([bankAccountUuid])
  @@index([authorUuid])
  @@index([date])
  @@index([basisDocumentUuid])
  @@index([updatedAt])
  @@map("bank_statements")
}

/// Настройки нумерации документов (переопределение префикса по виду документа).
/// Глобально для установки. Отсутствие строки → дефолт из
/// services/documentNumbering.js (NUMBER_CONFIG). Номер хранится и отображается
/// без ведущих нулей — разрядности (padding) больше нет.
model DocumentNumberSetting {
  id               Int      @id @default(autoincrement())
  /// Организация настройки. "__global__" — значения по умолчанию для всех орг.
  organizationUuid String   @default("__global__")
  docType          String
  prefix           String
  /// Включена ли автонумерация этого вида документа.
  enabled          Boolean  @default(true)
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([organizationUuid, docType])
  @@map("document_number_settings")
}

/// Документ «Установка цен номенклатуры» (периодический). Шапка.
/// Цены, проставленные проведённым документом, денормализуются в Product
/// (последний по дате проведённый документ задаёт текущие цены товара).
model ProductPriceSetting {
  id               Int                       @id @default(autoincrement())
  uuid             String                    @unique @default(uuid())
  number           String?
  date             DateTime                  @default(now())
  comment          String?
  organizationUuid String?
  posted           Boolean                   @default(false)
  authorUuid       String
  updatedAt        DateTime                  @default(now()) @updatedAt
  deletedAt        DateTime?
  items            ProductPriceSettingItem[]
  organization     Organization?             @relation(fields: [organizationUuid], references: [uuid])
  author           User                      @relation("PriceSettingAuthor", fields: [authorUuid], references: [uuid], onDelete: Restrict)

  @@index([organizationUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("product_price_settings")
}

/// Строка документа «Установка цен»: товар и три цены.
model ProductPriceSettingItem {
  id               Int                 @id @default(autoincrement())
  uuid             String              @unique @default(uuid())
  priceSettingUuid String
  productUuid      String?
  salePrice        Decimal?            @db.Decimal(18, 2)
  purchasePrice    Decimal?            @db.Decimal(18, 2)
  wholesalePrice   Decimal?            @db.Decimal(18, 2)
  updatedAt        DateTime            @default(now()) @updatedAt
  deletedAt        DateTime?
  priceSetting     ProductPriceSetting @relation(fields: [priceSettingUuid], references: [uuid], onDelete: Cascade)
  product          Product?            @relation(fields: [productUuid], references: [uuid])

  @@index([priceSettingUuid])
  @@index([productUuid])
  @@map("product_price_setting_items")
}

/// Справочник «Типы цен» (Цена продажи / закупки / оптовая и т.п.).
/// isDefault — тип, используемый как цена продажи по умолчанию (денормализуется
/// в Product.price для терминала и строк продаж).
model PriceType {
  id               Int            @id @default(autoincrement())
  uuid             String         @unique @default(uuid())
  name             String
  isDefault        Boolean        @default(false)
  sortOrder        Int            @default(100)
  organizationUuid String?
  updatedAt        DateTime       @default(now()) @updatedAt
  deletedAt        DateTime?
  productPrices    ProductPrice[]
  sales            Sale[]
  purchases        Purchase[]

  @@index([organizationUuid])
  @@map("price_types")
}

/// Цена номенклатуры по типу, действующая с указанной даты (вкладка «Цены» в
/// форме товара). Текущая цена типа = последняя по дате (date <= now).
model ProductPrice {
  id            Int        @id @default(autoincrement())
  uuid          String     @unique @default(uuid())
  productUuid   String
  priceTypeUuid String?
  date          DateTime   @default(now())
  price         Decimal?   @db.Decimal(18, 2)
  updatedAt     DateTime   @default(now()) @updatedAt
  deletedAt     DateTime?
  product       Product    @relation(fields: [productUuid], references: [uuid], onDelete: Cascade)
  priceType     PriceType? @relation(fields: [priceTypeUuid], references: [uuid])

  @@index([productUuid])
  @@index([priceTypeUuid])
  @@index([date])
  @@map("product_prices")
}

// ═══════════════════════════════════════════════════════════════════════════
// ЭДО (электронный документооборот с контрагентами) — внутрисистемный обмен
// юридически значимыми документами между организациями. Получатель резолвится
// по БИН (Counterparty.bin ↔ Organization.bin). Подпись — ЭЦП NCALayer.
// Ссылки на орг/пользователя — soft (uuid без FK, как AttachedFile);
// целостность обеспечивает роутер. Вложения — через AttachedFile
// (ownerType="edo_document"). Статусы — String (конвенция проекта).
// ═══════════════════════════════════════════════════════════════════════════

model EdoDocument {
  id   Int    @id @default(autoincrement())
  uuid String @unique @default(uuid())

  // Стороны обмена. sender* — отправитель (организация системы, tenant «Исходящие»).
  // receiver* — получатель по БИН; receiverOrgUuid заполняется, если контрагент —
  // организация системы (иначе null: «контрагент не подключён»).
  senderOrgUuid   String
  senderBin       String
  receiverBin     String
  receiverOrgUuid String?

  // Содержимое документа.
  kind          String // тип документа ЭДО: invoice|act|waybill|free|...
  title         String?
  number        String?
  date          DateTime @default(now())
  comment       String?
  // Необязательная связь с документом системы (Реализация/Счёт-фактура/…).
  sourceDocType String?
  sourceDocUuid String?
  // Канонический/подписываемый контент (XML) документа.
  canonicalXml  String?  @db.Text

  // Жизненный цикл: DRAFT|SENT|DELIVERED|SIGNED|ACCEPTED|REJECTED|REVOKED|ANNULLED
  status          String  @default("DRAFT")
  rejectionReason String?

  authorUuid  String // пользователь-создатель (отправитель)
  sentAt      DateTime?
  deliveredAt DateTime?
  respondedAt DateTime? // приём/отклонение получателем
  updatedAt   DateTime  @default(now()) @updatedAt
  deletedAt   DateTime?

  signatures EdoSignature[]

  @@index([senderOrgUuid])
  @@index([receiverOrgUuid])
  @@index([receiverBin])
  @@index([status])
  @@index([sourceDocType, sourceDocUuid])
  @@index([date])
  @@index([updatedAt])
  @@map("edo_documents")
}

model EdoSignature {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid())
  edoDocumentUuid String
  orgUuid         String // организация, от имени которой подписано
  userUuid        String? // пользователь-подписант
  role            String // sender|receiver
  signedXml       String?  @db.Text // подписанный XML (enveloped, NCALayer)
  certificate     String?  @db.Text // PEM/Base64 сертификата
  signedAt        DateTime @default(now())

  edoDocument EdoDocument @relation(fields: [edoDocumentUuid], references: [uuid], onDelete: Cascade)

  @@index([edoDocumentUuid])
  @@index([orgUuid])
  @@map("edo_signatures")
}

// ═══════════════════════════════════════════════════════════════════════════
// Классификаторы РК/ЕАЭС для гос-документов (ЭСФ/СНТ/ЭАВР). Единая таблица с
// дискриминатором type: "country"(ISO 3166) | "tnved"(ТН ВЭД ЕАЭС) |
// "kato"(регионы КАТО) | "gsvs"(ГС ВС, catalogTruId) | "mkei"(ед.изм) и т.д.
// Крупные официальные справочники (tnved/kato) наполняются импортом (POST
// /classifiers/import); страны сидируются. code уникален в пределах type.
// ═══════════════════════════════════════════════════════════════════════════
model Classifier {
  id         Int       @id @default(autoincrement())
  uuid       String    @unique @default(uuid())
  type       String
  code       String
  name       String
  parentCode String? // для иерархических (ТН ВЭД/КАТО)
  extra      Json?
  isActive   Boolean   @default(true)
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?

  @@unique([type, code])
  @@index([type])
  @@index([type, parentCode])
  @@map("classifiers")
}

// Системные настройки (key-value) — напр. конфиг интеграции eGov (egov.dataset,
// egov.apiKey и т.п.). Секреты хранятся только на сервере. Правит суперадмин.
model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String?
  updatedAt DateTime @default(now()) @updatedAt

  @@map("app_settings")
}
