# ── База данных ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# ── Сервер ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Авторизация (JWT) ────────────────────────────────────────
# Генерация: openssl rand -hex 64
JWT_SECRET=your_random_secret_here_use_openssl_rand_hex_64
JWT_EXPIRES_IN=24h

# ── CORS (разрешённые домены через запятую) ───────────────────
CORS_ORIGIN=http://localhost:5173
