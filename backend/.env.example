# ── База данных ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# ── Сервер ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Авторизация (JWT) ────────────────────────────────────────
# Генерация: openssl rand -hex 64
JWT_SECRET=your_random_secret_here_use_openssl_rand_hex_64
JWT_EXPIRES_IN=24h

# ── CORS (разрешённые домены через запятую) ───────────────────
CORS_ORIGIN=http://localhost:5173
# IP хоста(ов) cloudflared/обратного прокси через запятую. Если задано — к :3000
# допускаются только эти источники (+loopback). Пусто = гард выключен.
TRUSTED_PROXY_IPS=

# ── Фискальная интеграция (Kaspi) ─────────────────────────────
# По умолчанию stub (фейковые фискальные данные для разработки/тестов).
# Боевой режим: FISCAL_PROVIDER=kaspi + заполнить ключи (по договору с Kaspi).
FISCAL_PROVIDER=stub
KASPI_API_URL=
KASPI_API_TOKEN=
KASPI_TRADE_POINT_ID=

# ── ИС ЭСФ РК (электронные счета-фактуры) ─────────────────────
# Контур: test3 (тестовый, по умолчанию) | prod (боевой — НЕ для отладки).
# ESF_BASE_URL переопределяет контур целиком (напр. локальный сервер SDK).
ESF_ENV=test3
ESF_BASE_URL=
# БИН предприятия (обязателен для сессии) и код проекта (если выдан).
ESF_TIN=
ESF_PROJECT_CODE=
ESF_TIMEOUT_MS=30000
